<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="chamamember_list" model="ir.ui.view">
            <field name="name">chamamember_list</field>
            <field name="model">chamatech.member</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="phone" />
                    <field name="role_id" />
                    <field name="date_joined" /> <field name="total_contributions" sum="Grand Total" />
                </list>
            </field>
        </record>

        <!-- Form -->
        <record id="member_form" model="ir.ui.view">
            <field name="name">member.form</field>
            <field name="model">chamatech.member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="phone" />
                                <field name="role_id" />
                            </group>
                            <group>
                                <field name="date_joined" />
                                <field name="date_left" invisible="not date_left" />
                                <field name="active" widget="boolean_toggle" />
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search view filter -->
        <record id="view_member_filter" model="ir.ui.view">
            <field name="name">chamatech.member.search</field>
            <field name="model">chamatech.member</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="view_chama_member_form_inherit" model="ir.ui.view">
            <field name="name">chamatech.member.form.inherit</field>
            <field name="model">chamatech.member</field>
            <field name="inherit_id" ref="chama_tech.member_form"/> 
            <field name="arch" type="xml">
                <xpath expr="//group" position="after">
                    <group>
                        <field name="total_contributions" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Contributions" name="contributions">
                            <field name="contribution_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="amount" sum="Total"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>

        <!-- Action Window -->
        <record id="chamamember_action_window" model="ir.actions.act_window">
            <field name="name">Chama Member</field>
            <field name="res_model">chamatech.member</field>
            <field name="view_mode">list,form,kanban,pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first member
                </p>
                <p>
                    Add the people in your group here so you can start tracking their contributions and roles.
                </p>
            </field>
        </record>
    </data>   
</odoo>

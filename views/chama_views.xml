<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Views -->
      <!-- List -->
    <record id="chamatech_list" model="ir.ui.view">
      <field name="name">chamatech_list</field> 
      <field name="model">chamatech.chamatech</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="amount"/>
          <field name="description"/>
          <field name="status"/>
          <field name="frequency"/>
          <field name="date" />
        </list>
      </field>
    </record>
    <!-- Pivot -->
    <record id="chamatech_pivot" model="ir.ui.view">
      <field name="name">chamatech_pivot</field>
      <field name="model">chamatech.chamatech</field>
      <field name="arch" type="xml">
        <pivot string="Financial Analysis" disable_linking="true">
          <field name="name" type="row" />
          <field name="amount" type="measure" />
          <!-- <field name="status" type="col"/> -->
          <field name="frequency" type="col" /> 
        </pivot>
      </field>
    </record>

    <!-- Kanban -->
    <record id="chamatech_kanban" model="ir.ui.view">
      <field name="name">chamatech_kanban</field>
      <field name="model">chamatech.chamatech</field>
      <field name="arch" type="xml">
        <kanban default_group_by="status">
          <field name="name" />
          <field name="amount" />
          <field name="status" />
          <field name="frequency" />
          <templates>
            <t t-name="card">
              <div class="oe_kanban_global_click">
                <div class="o_kanban_record_top">
                  <strong>
                    <field name="name" />
                  </strong>
                </div>
                <div class="oe_kanban_details">
                  <span>Amount: </span> <field name="amount" />
                  <br/>
                  <span>Frequency: </span> <field name="frequency" />
                </div>
                <div class="o_kanban_record_bottom">
                  <span>Status: </span> <field name="status" />
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- Form -->
    <record id="chamatech_form" model="ir.ui.view">
      <field name="name">chamatech_form</field>
      <field name="model">chamatech.chamatech</field>
      <field name="arch" type="xml">
        <form> 
          <header>
            <field name="status" widget="statusbar"/>
          </header>
          <sheet> 
            <group>
              <field name="name"/>
              <field name="amount"/>
              <field name="description"/>
              <field name="frequency"/>
              <field name="status"/>
              <field name="date" />
            </group>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <record id="chamatech_action_window" model="ir.actions.act_window">
      <field name="name">Chama Tech</field>
      <field name="res_model">chamatech.chamatech</field>
      <field name="view_mode">list,form,kanban,pivot,graph</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Add a new record
        </p>
        <p>
          Welcome to Chama Tech, make your first contribution.
        </p>
      </field>
    </record>
  </data>
</odoo>
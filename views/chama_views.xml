<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="chamatech_list" model="ir.ui.view">
      <field name="name">chamatech_list</field> <field name="model">chamatech.chamatech</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="amount"/>
          <field name="description"/>
          <field name="status"/>
          <field name="frequency"/>
        </list>
      </field>
    </record>

    <record id="chamatech_form" model="ir.ui.view">
      <field name="name">chamatech_form</field> <field name="model">chamatech.chamatech</field>
      <field name="arch" type="xml">
        <form> 
          <header>
            <field name="status" widget="statusbar"/>
          </header>
          <sheet> 
            <group>
              <field name="name"/>
              <field name="amount"/>
              <field name="description"/>
              <field name="frequency"/>
              <field name="status"/>
            </group>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <record id="chamatech_action_window" model="ir.actions.act_window">
      <field name="name">Chama Tech</field>
      <field name="res_model">chamatech.chamatech</field>
      <field name="view_mode">list,form,kanban,pivot,graph</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Add a new record
        </p>
        <p>
          Welcome to Chama Tech, make your first contribution.
        </p>
      </field>
    </record>

    <menuitem name="ChamaTech" id="chamatech_menu_root"/>

    <menuitem name="Admin" id="chamatech_menu_1" 
              parent="chamatech_menu_root"/>
    
    <menuitem name="Members" id="chamatech_menu_1_list" 
              parent="chamatech_menu_1" 
              action="chamatech_action_window"/> </data>
</odoo>
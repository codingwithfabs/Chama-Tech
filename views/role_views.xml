<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="chamarole_list" model="ir.ui.view">
            <field name="name">chamarole_list</field>
            <field name="model">chamatech.role</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="availability" />
                </list>
            </field>
        </record>

        <record id="view_chamatech_role_history_form" model="ir.ui.view">
            <field name="name">chamatech.role.history.form</field>
            <field name="model">chamatech.role.history</field>
            <field name="arch" type="xml">
                <form string="Role History">
                    <sheet>
                        <group>
                            <group>
                                <field name="member_id" readonly="1"/>
                                <field name="role_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="date_assigned" readonly="1"/>
                                <field name="date_resigned" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Form -->
        <record id="roles_form" model="ir.ui.view">
            <field name="name">roles_form</field>
            <field name="model">chamatech.role</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="availability" />
                            <field name="member_ids" widget="list" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Ownership History" name="history">
                                <field name="history_ids" readonly="1">
                                    <list create="false" edit="false">
                                        <field name="member_id" />
                                        <field name="role_id" />
                                        <field name="date_assigned" />
                                        <field name="date_resigned" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Action Windows -->
        <record id="chamarole_action_window" model="ir.actions.act_window">
            <field name="name">Chama Role's</field>
            <field name="res_model">chamatech.role</field>
            <field name="view_mode">list,form,kanban,pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Assign your first role
                </p>
                <p>
                    Manage your members by assigning roles
                </p>
            </field>
        </record>
    </data>
</odoo>
